# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Sentry
SENTRY_DSN=https://...@sentry.io/...

# Arize
ARIZE_API_KEY=...
ARIZE_SPACE_KEY=...
ARIZE_MODEL_ID=quorum-validators

# Browserbase (web verification)
BROWSERBASE_API_KEY=...
BROWSERBASE_PROJECT_ID=...

# Consensus thresholds (optional overrides)
CONSENSUS_ACCEPT_THRESHOLD=0.70
CONSENSUS_REJECT_THRESHOLD=0.30

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Agentverse deployment (run_agentverse.py only — not needed for the demo)
AGENTVERSE_API_KEY=...          # get from agentverse.ai → My Agents → API Keys
AGENT_SEED=quorum_agentverse_seed_v1   # keep this fixed so the agent address never changes
AGENT_NAME=quorum-validator
